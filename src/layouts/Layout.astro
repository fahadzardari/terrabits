---
import Footer from "../components/common/Footer.astro";

const { title = "Terrabits", bg = "#f8f8f8" } = Astro.props;
import "../index.css";
import Navbar from "../components/common/Navbar.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.png" />
        <meta name="generator" content={Astro.generator} />
        <!-- Google Tag Manager -->
        <script is:inline>
            (function (w, d, s, l, i) {
                w[l] = w[l] || [];
                w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
                var f = d.getElementsByTagName(s)[0],
                    j = d.createElement(s),
                    dl = l != "dataLayer" ? "&l=" + l : "";
                j.async = true;
                j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
                f.parentNode.insertBefore(j, f);
            })(window, document, "script", "dataLayer", "GTM-N9LLLDRT");
        </script>
        <!-- End Google Tag Manager -->
        <title>{title}</title>
    </head>
    <body
        class={`m-0 flex min-h-screen min-w-screen flex-col gap-y-0 overflow-x-hidden p-0 bg-[${bg}]`}
    >
        <!-- Google Tag Manager (noscript) -->
        <noscript
            ><iframe
                src="https://www.googletagmanager.com/ns.html?id=GTM-N9LLLDRT"
                height="0"
                width="0"
                style="display:none;visibility:hidden"
            ></iframe></noscript
        >
        <!-- End Google Tag Manager (noscript) -->
        <Navbar />
        <slot />
        <Footer />

        <!-- Global Calendly URL (used by ContactModal) -->
        <script is:inline>
            window.CALENDLY_URL = "https://calendly.com/info-terrabits/30min";
        </script>
        <script
            is:inline
            src="https://app.termly.io/resource-blocker/81902f4f-629e-4b9a-9e1b-63d6c4053f22?autoBlock=on"
        ></script>
    </body>
</html>
